<!DOCTYPE html>
<html lang="zh-Hant" class="antialiased">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BIM-Flow V2 | AI Construction OS</title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
    
    <!-- Icons (FontAwesome for quick prototype, can swap to Heroicons SVG later) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Tailwind CSS (CDN for prototyping) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        mono: ['IBM Plex Mono', 'monospace'],
                    },
                    colors: {
                        brand: {
                            50: '#f0fdfa',
                            100: '#ccfbf1',
                            500: '#14b8a6', // Primary Teal
                            600: '#0d9488',
                            900: '#134e4a',
                        },
                        surface: {
                            dark: '#0f172a',  // Slate 900
                            darker: '#020617', // Slate 950
                            panel: 'rgba(30, 41, 59, 0.7)', // Glass UI Dark
                        }
                    }
                }
            }
        }
    </script>

    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
        .dark ::-webkit-scrollbar-thumb { background: #334155; }
        
        /* Glassmorphism utilities */
        .glass-panel {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }
        .dark .glass-panel {
            background: rgba(30, 41, 59, 0.7);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
    </style>
</head>
<body class="bg-gray-50 text-gray-900 dark:bg-surface-darker dark:text-gray-100 transition-colors duration-200" x-data="{ darkMode: true, sidebarOpen: true }" :class="{ 'dark': darkMode }">

    <!-- App Container -->
    <div class="flex h-screen overflow-hidden">

        <!-- Sidebar -->
        <aside class="flex-shrink-0 w-64 flex flex-col border-r border-gray-200 dark:border-gray-800 bg-white dark:bg-surface-dark transition-all duration-300"
               :class="{'w-64': sidebarOpen, 'w-20': !sidebarOpen}">
            
            <!-- Logo Area -->
            <div class="h-16 flex items-center px-4 border-b border-gray-200 dark:border-gray-800 justify-between">
                <div class="flex items-center gap-3 overflow-hidden">
                    <div class="w-8 h-8 rounded bg-brand-500 flex items-center justify-center text-white font-bold shrink-0">B</div>
                    <span class="font-bold text-lg tracking-tight whitespace-nowrap" x-show="sidebarOpen">BIM-Flow</span>
                </div>
                <button @click="sidebarOpen = !sidebarOpen" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200">
                    <i class="fa-solid fa-bars"></i>
                </button>
            </div>

            <!-- Navigation -->
            <nav class="flex-1 overflow-y-auto py-4 px-3 space-y-1 custom-scrollbar">
                <!-- Group: Overview -->
                <div class="mb-4">
                    <p class="px-3 text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2" x-show="sidebarOpen">Overview</p>
                    <a href="#" class="flex items-center gap-3 px-3 py-2 rounded-lg bg-brand-50 text-brand-600 dark:bg-brand-900/30 dark:text-brand-500 transition-colors">
                        <i class="fa-solid fa-chart-pie w-5 text-center"></i>
                        <span x-show="sidebarOpen" class="font-medium text-sm">Dashboard</span>
                    </a>
                    <a href="#" class="flex items-center gap-3 px-3 py-2 rounded-lg text-gray-600 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 transition-colors">
                        <i class="fa-solid fa-building w-5 text-center"></i>
                        <span x-show="sidebarOpen" class="font-medium text-sm">專案首頁</span>
                    </a>
                </div>

                <!-- Group: Execution -->
                <div class="mb-4">
                    <p class="px-3 text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2" x-show="sidebarOpen">Execution</p>
                    <a href="#" class="flex items-center gap-3 px-3 py-2 rounded-lg text-gray-600 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 transition-colors">
                        <i class="fa-solid fa-network-wired w-5 text-center"></i>
                        <span x-show="sidebarOpen" class="font-medium text-sm">WBS Explorer</span>
                    </a>
                    <a href="#" class="flex items-center gap-3 px-3 py-2 rounded-lg text-gray-600 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 transition-colors">
                        <i class="fa-solid fa-bars-progress w-5 text-center"></i>
                        <span x-show="sidebarOpen" class="font-medium text-sm">施工進度</span>
                    </a>
                </div>

                <!-- Group: Quality & AI -->
                <div class="mb-4">
                    <p class="px-3 text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2" x-show="sidebarOpen">Quality & AI</p>
                    <a href="#" class="flex items-center gap-3 px-3 py-2 rounded-lg text-gray-600 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 transition-colors">
                        <i class="fa-solid fa-robot w-5 text-center"></i>
                        <span x-show="sidebarOpen" class="font-medium text-sm">AI 照片辨識</span>
                    </a>
                    <a href="#" class="flex items-center gap-3 px-3 py-2 rounded-lg text-gray-600 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 transition-colors">
                        <i class="fa-solid fa-triangle-exclamation w-5 text-center"></i>
                        <span x-show="sidebarOpen" class="font-medium text-sm">異常管理</span>
                        <span x-show="sidebarOpen" class="ml-auto bg-red-500 text-white text-xs py-0.5 px-2 rounded-full">8</span>
                    </a>
                </div>
            </nav>

            <!-- User Profile -->
            <div class="p-4 border-t border-gray-200 dark:border-gray-800">
                <div class="flex items-center gap-3">
                    <img src="https://ui-avatars.com/api/?name=Admin&background=14b8a6&color=fff" alt="User" class="w-8 h-8 rounded-full">
                    <div class="overflow-hidden" x-show="sidebarOpen">
                        <p class="text-sm font-medium truncate">營造廠管理員</p>
                        <p class="text-xs text-gray-500 truncate">admin@bim-flow.com</p>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col relative overflow-hidden bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMSIgY3k9IjEiIHI9IjEiIGZpbGw9InJnYmEoMTQ4LCAxNjMsIDE4NCwgMC4xKSIvPjwvc3ZnPg==')]">
            
            <!-- Header -->
            <header class="h-16 glass-panel border-b z-10 flex items-center justify-between px-6 sticky top-0">
                <!-- Breadcrumbs -->
                <div class="flex items-center text-sm font-medium text-gray-500 dark:text-gray-400">
                    <a href="#" class="hover:text-brand-500 transition-colors">專案列表</a>
                    <i class="fa-solid fa-chevron-right text-[10px] mx-3"></i>
                    <a href="#" class="hover:text-brand-500 transition-colors">新莊集合住宅A案</a>
                    <i class="fa-solid fa-chevron-right text-[10px] mx-3"></i>
                    <span class="text-gray-900 dark:text-gray-100">Dashboard</span>
                </div>

                <!-- Top Actions -->
                <div class="flex items-center gap-4">
                    <button class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 relative">
                        <i class="fa-regular fa-bell text-lg"></i>
                        <span class="absolute -top-1 -right-1 flex h-3 w-3">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-3 w-3 bg-brand-500"></span>
                        </span>
                    </button>
                    <!-- Dark/Light Mode Toggle -->
                    <button @click="darkMode = !darkMode" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200">
                        <i class="fa-solid fa-moon text-lg" x-show="!darkMode"></i>
                        <i class="fa-solid fa-sun text-lg" x-show="darkMode"></i>
                    </button>
                </div>
            </header>

            <!-- Page Content (Scrollable) -->
            <div class="flex-1 overflow-y-auto p-6 custom-scrollbar">
                
                <!-- Page Title -->
                <div class="mb-6 flex justify-between items-end">
                    <div>
                        <h1 class="text-2xl font-bold text-gray-900 dark:text-white tracking-tight">專案儀表板</h1>
                        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">即時掌握施工進度、KPI 與高風險異常。</p>
                    </div>
                    <div class="flex gap-2">
                        <button class="px-4 py-2 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors shadow-sm">
                            <i class="fa-solid fa-download mr-2"></i>匯出報表
                        </button>
                        <button class="px-4 py-2 bg-brand-500 text-white rounded-lg text-sm font-medium hover:bg-brand-600 transition-colors shadow-sm shadow-brand-500/30">
                            <i class="fa-solid fa-plus mr-2"></i>新增任務
                        </button>
                    </div>
                </div>

                <!-- Content Area (Ready for Phase 2 components) -->
                <div class="glass-panel rounded-xl p-8 border border-dashed border-gray-300 dark:border-gray-700 flex flex-col items-center justify-center text-gray-400 min-h-[400px]">
                    <i class="fa-solid fa-layer-group text-4xl mb-4 text-gray-300 dark:text-gray-600"></i>
                    <p class="font-mono text-sm">Content Area: Ready for Phase 2 (Dashboard Components)</p>
                </div>

            </div>
        </main>
    </div>

</body>
</html>
